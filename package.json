{
  "name": "pocketdeck",
  "version": "0.1.0",
  "private": true,
  "description": "PocketDeck, premium 3D product showcase for a fingerboard skate",
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:web": "pnpm --filter @pocketdeck/web dev",
    "dev:api": "pnpm --filter @pocketdeck/api dev",
    "build": "pnpm -r run build",
    "build:types": "pnpm --filter @pocketdeck/types build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "seed": "pnpm --filter @pocketdeck/api seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.2.2"
}
