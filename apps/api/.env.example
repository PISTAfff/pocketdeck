# Express API config
PORT=4000
NODE_ENV=development

# CORS — origin(s) where the Next.js app runs. Comma-separated for multiple.
# In production, list your Vercel production domain (and any preview branch
# domains you want to allow). Example:
#   WEB_ORIGIN=https://pocketdeck.vercel.app,https://pocketdeck-git-main.vercel.app
WEB_ORIGIN=http://localhost:3000

# MongoDB. For local dev: a Mongo running on 27017. For production: a
# MongoDB Atlas connection string (mongodb+srv://...). Put real secrets in
# .env (gitignored), NOT this file.
#
# REQUIRED in production — the API refuses to boot without it.
MONGODB_URI=mongodb://127.0.0.1:27017/pocketdeck

# Rate limiting (per IP, per minute) on POST routes
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Admin dashboard password.
#
# REQUIRED in production — the API refuses to boot if this is unset, still
# equal to the dev default "pocketdeck-admin", or shorter than 12 chars.
ADMIN_PASSWORD=pocketdeck-admin

# How long an admin session token stays valid before re-login is required.
# Defaults to 12h. Increase only if you've thought about the tradeoff.
ADMIN_TOKEN_TTL_MS=43200000

# Injected automatically by Render — points at the public https URL of
# this service. Used as the target for the self-ping keep-warm loop, so
# the free-tier dyno doesn't spin down between requests. Leave blank in
# local dev to skip the loop entirely.
RENDER_EXTERNAL_URL=
