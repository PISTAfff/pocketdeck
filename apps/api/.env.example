# Express API config
PORT=4000
NODE_ENV=development

# CORS, must match the origin where the Next.js app runs
WEB_ORIGIN=http://localhost:3000

# MongoDB, local instance for dev. The seed script populates the PocketDeck product.
# For Atlas, put your real connection string in .env (NOT this file, this file
# is tracked by git).
MONGODB_URI=mongodb://127.0.0.1:27017/pocketdeck

# Rate limiting (per IP, per minute) on POST routes
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
