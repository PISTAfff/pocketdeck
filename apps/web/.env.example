# The API origin the browser talks to directly (no proxy).
#
# Dev:  http://localhost:4000
# Prod: your deployed API host, e.g. https://pocketdeck-api.onrender.com
#
# Set this in Vercel under Project → Settings → Environment Variables for
# every environment you deploy (Production / Preview / Development).
# NEXT_PUBLIC_* values are baked at build time, so changing this requires
# a redeploy to take effect.
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000
